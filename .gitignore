# =================================================================
# .gitignore - אל תעלה את הקבצים האלה ל-GitHub!
# =================================================================

# 🔒 קובץ הגדרות עם סיסמאות - אסור ב-GitHub!
api/config.php

# 🔒 לוגים - לא לעלות (יכולים להכיל מידע רגיש)
logs/*.log
*.log

# 🔒 קבצי התקנה - אמורים להיות מחוקים מהשרת אחרי התקנה
install.php
server-check.php

# 🔒 משתני סביבה
.env
.env.local
.env.production

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Temp files
*.tmp
*.bak
*.backup

# Composer (אם בעתיד)
vendor/
composer.lock

# Node modules (אם בעתיד)
node_modules/
npm-debug.log
